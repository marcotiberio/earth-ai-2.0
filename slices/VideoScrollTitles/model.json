{
  "id": "video_scroll_titles",
  "type": "SharedSlice",
  "name": "VideoScrollTitles",
  "description": "Pinned full-bleed scroll-scrub video with a repeatable group of headline titles overlaid; each title brightens from 20% to 100% opacity in turn as the section scrolls.",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Pinned video with a stack of titles that reveal in sequence on scroll.",
      "imageUrl": "",
      "primary": {
        "is_hidden": {
          "type": "Boolean",
          "config": {
            "label": "Hide slice",
            "placeholder_false": "Visible",
            "placeholder_true": "Hidden",
            "default_value": false
          }
        },
        "gradient_top": {
          "type": "Boolean",
          "config": {
            "label": "Top gradient",
            "placeholder_false": "Hidden",
            "placeholder_true": "Visible",
            "default_value": true
          }
        },
        "gradient_bottom": {
          "type": "Boolean",
          "config": {
            "label": "Bottom gradient",
            "placeholder_false": "Hidden",
            "placeholder_true": "Visible",
            "default_value": true
          }
        },
        "video_url": {
          "type": "Link",
          "config": {
            "label": "Background video",
            "placeholder": "Upload or select a video from the Media Library",
            "select": "media"
          }
        },
        "video_url_hevc": {
          "type": "Link",
          "config": {
            "label": "Background video (HEVC, optional)",
            "placeholder": "Optional .scrub.hevc.mp4 — served to Safari/iOS, ~40% smaller",
            "select": "media"
          }
        },
        "image": {
          "type": "Image",
          "config": {
            "label": "Background image (poster / fallback)",
            "constraint": {},
            "thumbnails": []
          }
        },
        "scroll_length": {
          "type": "Number",
          "config": {
            "label": "Scroll length (vh)",
            "placeholder": "Pinned scroll distance in vh (default: 300)"
          }
        },
        "scrub_start": {
          "type": "Select",
          "config": {
            "label": "Scrub start",
            "placeholder": "When the scroll-scrub begins (default: full travel)",
            "options": [
              "top",
              "middle"
            ]
          }
        },
        "title": {
          "type": "StructuredText",
          "config": {
            "label": "End title",
            "placeholder": "Headline that wipes in over the second half of the scroll",
            "allowTargetBlank": true,
            "single": "paragraph,strong,em"
          }
        },
        "title_align": {
          "type": "Select",
          "config": {
            "label": "End title vertical alignment",
            "placeholder": "center",
            "options": [
              "top",
              "center",
              "bottom"
            ]
          }
        },
        "title_align_x": {
          "type": "Select",
          "config": {
            "label": "End title horizontal alignment",
            "placeholder": "center",
            "options": [
              "left",
              "center",
              "right"
            ]
          }
        },
        "items": {
          "type": "Group",
          "config": {
            "label": "Titles",
            "fields": {
              "title": {
                "type": "Text",
                "config": {
                  "label": "Title",
                  "placeholder": "e.g. AI Data Centres"
                }
              }
            }
          }
        }
      },
      "items": {}
    }
  ]
}
