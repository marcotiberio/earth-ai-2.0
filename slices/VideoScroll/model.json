{
  "id": "video_scroll",
  "type": "SharedSlice",
  "name": "VideoScroll",
  "description": "Pinned full-bleed video/image with a headline that scrolls over it.",
  "variations": [
    {
      "id": "overlay",
      "name": "Overlay",
      "docURL": "...",
      "version": "initial",
      "description": "Pinned full-bleed background with an overlaid headline.",
      "imageUrl": "",
      "primary": {
        "is_hidden": {
          "type": "Boolean",
          "config": {
            "label": "Hide slice",
            "placeholder_false": "Visible",
            "placeholder_true": "Hidden",
            "default_value": false
          }
        },
        "frame": {
          "type": "Boolean",
          "config": {
            "label": "Play video in a frame",
            "placeholder_false": "Full-bleed",
            "placeholder_true": "Framed",
            "default_value": false
          }
        },
        "gradient_top": {
          "type": "Boolean",
          "config": {
            "label": "Top gradient",
            "placeholder_false": "Hidden",
            "placeholder_true": "Visible",
            "default_value": true
          }
        },
        "gradient_bottom": {
          "type": "Boolean",
          "config": {
            "label": "Bottom gradient",
            "placeholder_false": "Hidden",
            "placeholder_true": "Visible",
            "default_value": true
          }
        },
        "video_url": {
          "type": "Link",
          "config": {
            "label": "Background video (desktop)",
            "placeholder": "Upload or select a video from the Media Library",
            "select": "media"
          }
        },
        "video_url_mobile": {
          "type": "Link",
          "config": {
            "label": "Background video (mobile, optional)",
            "placeholder": "Optional — served on small screens; falls back to the desktop video",
            "select": "media"
          }
        },
        "image": {
          "type": "Image",
          "config": {
            "label": "Background image",
            "constraint": {},
            "thumbnails": []
          }
        },
        "scroll_length": {
          "type": "Number",
          "config": {
            "label": "Scroll length (vh)",
            "placeholder": "Pinned scroll distance in vh (default: 300)"
          }
        },
        "scrub_start": {
          "type": "Select",
          "config": {
            "label": "Scrub start",
            "placeholder": "When the scroll-scrub begins (default: full travel)",
            "options": [
              "top",
              "middle"
            ]
          }
        },
        "title": {
          "type": "StructuredText",
          "config": {
            "label": "Title",
            "placeholder": "Headline",
            "allowTargetBlank": true,
            "single": "heading1,heading2,heading3,strong,em"
          }
        },
        "title_align_vertical": {
          "type": "Select",
          "config": {
            "label": "Title vertical position",
            "placeholder": "Vertical position (default: bottom)",
            "options": [
              "top",
              "center",
              "bottom"
            ],
            "default_value": "bottom"
          }
        },
        "title_align_horizontal": {
          "type": "Select",
          "config": {
            "label": "Title horizontal position",
            "placeholder": "Horizontal position (default: left)",
            "options": [
              "left",
              "center",
              "right"
            ],
            "default_value": "left"
          }
        },
        "subtitle": {
          "type": "StructuredText",
          "config": {
            "label": "Subtitle",
            "placeholder": "Supporting caption",
            "allowTargetBlank": true,
            "single": "paragraph,strong,em,hyperlink"
          }
        },
        "subtitle_align_vertical": {
          "type": "Select",
          "config": {
            "label": "Subtitle vertical position",
            "placeholder": "Vertical position (default: bottom)",
            "options": [
              "top",
              "center",
              "bottom"
            ],
            "default_value": "bottom"
          }
        },
        "subtitle_align_horizontal": {
          "type": "Select",
          "config": {
            "label": "Subtitle horizontal position",
            "placeholder": "Horizontal position (default: left)",
            "options": [
              "left",
              "center",
              "right"
            ],
            "default_value": "left"
          }
        }
      },
      "items": {}
    }
  ]
}
