{
  "id": "drilled_stats",
  "type": "SharedSlice",
  "name": "DrilledStats",
  "description": "Pinned scene: a WYSIWYG title with count-up metrics beside an in-frame video that scrubs on scroll. Add up to 4 stat rows.",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Default",
      "imageUrl": "",
      "primary": {
        "is_hidden": {
          "type": "Boolean",
          "config": {
            "label": "Hide slice",
            "placeholder_false": "Visible",
            "placeholder_true": "Hidden",
            "default_value": false
          }
        },
        "scroll_length": {
          "type": "Number",
          "config": {
            "label": "Scroll length (vh)",
            "placeholder": "Pinned scroll distance in vh (default: 300)"
          }
        },
        "scrub_start": {
          "type": "Select",
          "config": {
            "label": "Scrub start",
            "placeholder": "When the scroll-scrub begins (default: full travel)",
            "options": [
              "top",
              "middle"
            ]
          }
        },
        "title": {
          "type": "StructuredText",
          "config": {
            "label": "Title",
            "placeholder": "Headline (e.g. We drilled through the stratosphere.)",
            "allowTargetBlank": true,
            "single": "paragraph,strong,em"
          }
        },
        "video_url": {
          "type": "Link",
          "config": {
            "label": "Scrub video (desktop)",
            "placeholder": "Upload or select a video from the Media Library",
            "select": "media"
          }
        },
        "video_url_mobile": {
          "type": "Link",
          "config": {
            "label": "Scrub video (mobile, optional)",
            "placeholder": "Optional — served on small screens; falls back to the desktop video",
            "select": "media"
          }
        },
        "image": {
          "type": "Image",
          "config": {
            "label": "Poster / fallback image",
            "constraint": {},
            "thumbnails": []
          }
        },
        "stats": {
          "type": "Group",
          "config": {
            "label": "Stats (max 6)",
            "fields": {
              "label": {
                "type": "Text",
                "config": {
                  "label": "Title",
                  "placeholder": "e.g. Deposits"
                }
              },
              "value": {
                "type": "Text",
                "config": {
                  "label": "Number",
                  "placeholder": "e.g. 6 or 4.1 mil (counts up on scroll)"
                }
              }
            }
          }
        }
      },
      "items": {}
    }
  ]
}
