{
  "id": "hero_image",
  "type": "SharedSlice",
  "name": "HeroImage",
  "description": "Full-bleed hero with a background video/image and an overlaid title and subtitle.",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Default",
      "imageUrl": "",
      "primary": {
        "is_hidden": {
          "type": "Boolean",
          "config": {
            "label": "Hide slice",
            "placeholder_false": "Visible",
            "placeholder_true": "Hidden",
            "default_value": false
          }
        },
        "video_url": {
          "type": "Link",
          "config": {
            "label": "Background video (desktop)",
            "placeholder": "Upload or select a video from the Media Library",
            "select": "media"
          }
        },
        "video_url_mobile": {
          "type": "Link",
          "config": {
            "label": "Background video (mobile, optional)",
            "placeholder": "Optional — served on small screens; falls back to the desktop video",
            "select": "media"
          }
        },
        "image": {
          "type": "Image",
          "config": {
            "label": "Background image",
            "constraint": {},
            "thumbnails": []
          }
        },
        "title": {
          "type": "StructuredText",
          "config": {
            "label": "Title",
            "placeholder": "Headline",
            "allowTargetBlank": true,
            "single": "heading1,strong,em"
          }
        },
        "subtitle": {
          "type": "StructuredText",
          "config": {
            "label": "Subtitle",
            "placeholder": "Supporting copy",
            "allowTargetBlank": true,
            "multi": "paragraph,strong,em"
          }
        },
        "scroll_length": {
          "type": "Number",
          "config": {
            "label": "Scroll length (vh)",
            "placeholder": "Pinned scroll distance in vh (default: 300)"
          }
        },
        "scrub_start": {
          "type": "Select",
          "config": {
            "label": "Scrub start",
            "placeholder": "When the scroll-scrub begins (default: full travel)",
            "options": [
              "top",
              "middle"
            ]
          }
        }
      },
      "items": {}
    }
  ]
}
