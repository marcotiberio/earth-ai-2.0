{
  "id": "text_content",
  "type": "SharedSlice",
  "name": "TextContent",
  "description": "A simple rich-text block — heading plus formatted body copy. Use it to build text-only pages like Terms of Service or Privacy Policy.",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Heading, optional sub-line, and a rich-text body.",
      "imageUrl": "",
      "primary": {
        "is_hidden": {
          "type": "Boolean",
          "config": {
            "label": "Hide slice",
            "placeholder_false": "Visible",
            "placeholder_true": "Hidden",
            "default_value": false
          }
        },
        "title": {
          "type": "Text",
          "config": {
            "label": "Title",
            "placeholder": "e.g. Terms of Service"
          }
        },
        "subtitle": {
          "type": "Text",
          "config": {
            "label": "Sub-line",
            "placeholder": "Optional, e.g. Last modified: September 6th 2023"
          }
        },
        "content": {
          "type": "StructuredText",
          "config": {
            "label": "Content",
            "placeholder": "Write the page content…",
            "allowTargetBlank": true,
            "multi": "paragraph,preformatted,heading2,heading3,heading4,strong,em,hyperlink,list-item,o-list-item,rtl"
          }
        }
      },
      "items": {}
    }
  ]
}
